nextflow_pipeline {

    name "Test pipeline with test_longreadonly_alternatives profile"
    script "../main.nf"
    tag "pipeline"
    tag "test_longreadonly_alternatives"
    profile "test_longreadonly_alternatives"

    test("-profile longreadonly_alternatives") {

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            // Output directory: QC_longreads
            def stable_name_qc = getAllFilesFromDir(
                params.outdir, include: ['QC_longreads/**'], relative: true, includeDir: false
            )
            def stable_path_qc = getAllFilesFromDir(
                params.outdir, include: ['QC_longreads/**'], ignoreFile: 'tests/.nftignore'
            )
            def nanoq_stats = getAllFilesFromDir(
                params.outdir, include: ['QC_longreads/Nanoq/*.stats']
            )
            def nanolyse_logs = getAllFilesFromDir(
                params.outdir, include: ['QC_longreads/NanoLyse/*.log']
            )
            def nanoplot_stats = getAllFilesFromDir(
                params.outdir, include: ['QC_longreads/NanoPlot/*/*NanoStats.txt']
            )

            // Output directory: Assembly
            def stable_name_assembly = getAllFilesFromDir(
                params.outdir, include: ['Assembly/**'], relative: true, includeDir: false
            )
            def stable_path_assembly = getAllFilesFromDir(
                params.outdir, include: ['Assembly/**'], ignoreFile: 'tests/.nftignore'
            )
            def flye_assemblies = getAllFilesFromDir(
                params.outdir, include: ['Assembly/FLYE/*.assembly.fasta.gz']
            )
            def flye_graphs = getAllFilesFromDir(
                params.outdir, include: ['Assembly/FLYE/*.assembly_graph.gfa.gz']
            )
            def flye_logs = getAllFilesFromDir(
                params.outdir, include: ['Assembly/FLYE/*.flye.log']
            )

            // Output directory: GenomeBinning
            def stable_name_binning = getAllFilesFromDir(
                params.outdir, include: ['GenomeBinning/**'], relative: true, includeDir: false
            )
            def stable_path_binning = getAllFilesFromDir(
                params.outdir, include: ['GenomeBinning/**'], ignoreFile: 'tests/.nftignore'
            )
            def maxbin2_bins = getAllFilesFromDir(
                params.outdir, include: ['GenomeBinning/MaxBin2/bins/*.fa.gz']
            )
            def maxbin2_unbins = getAllFilesFromDir(
                params.outdir, include: ['GenomeBinning/MaxBin2/{discarded,unbinned/*}/*.{gz,fa.gz}']
            )
            def metabat2_bins = getAllFilesFromDir(
                params.outdir, include: ['GenomeBinning/MetaBAT2/bins/*.fa.gz']
            )
            def metabat2_unbins = getAllFilesFromDir(
                params.outdir, include: ['GenomeBinning/MetaBAT2/{discarded,unbinned/*}/*.fa.gz']
            )
            def bin_summary = path("${params.outdir}/GenomeBinning/bin_summary.tsv")
            def busco_summary = path("${params.outdir}/GenomeBinning/QC/busco_summary.tsv")
            def bin_depths_summary = path("${params.outdir}/GenomeBinning/depths/bins/bin_depths_summary.tsv")
            def maxbin2_summary = path("${params.outdir}/GenomeBinning/MaxBin2/FLYE-MaxBin2-minigut.summary")
            def busco_batch_summaries = getAllFilesFromDir(
                params.outdir, include: ['GenomeBinning/QC/BUSCO/**/*-busco.batch_summary.txt']
            )

            // Output directory: multiqc
            def stable_name_multiqc = getAllFilesFromDir(
                params.outdir, include: ['multiqc/**'], relative: true, includeDir: false
            )
            def stable_path_multiqc = getAllFilesFromDir(
                params.outdir, include: ['multiqc/**'], ignoreFile: 'tests/.nftignore'
            )

            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.trace.succeeded().size(),
                    removeNextflowVersion("$outputDir/pipeline_info/nf_core_mag_software_mqc_versions.yml"),
                ).match() },
                { assert snapshot(stable_name_qc,       stable_path_qc      ).match('qc') },
                { assert snapshot(stable_name_assembly, stable_path_assembly).match('assembly') },
                { assert snapshot(stable_name_binning,  stable_path_binning ).match('binning') },
                { assert snapshot(stable_name_multiqc, stable_path_multiqc).match('multiqc') },
                { assert snapshot(
                    "Bin summary: ${bin_summary.csv(sep: '\t').rowCount}",
                    "BUSCO summary: ${busco_summary.csv(sep: '\t').rowCount}",
                    "Bin depths summary: ${bin_depths_summary.csv(sep: '\t').rowCount}",
                    "MaxBin2 summary: ${maxbin2_summary.csv(sep: '\t').rowCount}",
                ).match("summary-rows") },
                { assert snapshot(
                    "Nanoq stats non-empty: ${nanoq_stats.collect { file -> path("${file}").size() > 0 }.every()}",
                    "Nanoq stats contain read count: ${nanoq_stats.collect { file -> path("${file}").text.contains('Number of reads:') }.every()}",
                    "NanoLyse logs non-empty: ${nanolyse_logs.collect { file -> path("${file}").size() > 0 }.every()}",
                    "NanoPlot stats contain summaries: ${nanoplot_stats.collect { file -> path("${file}").text.contains('General summary:') }.every()}",
                    "NanoPlot stats non-empty: ${nanoplot_stats.collect { file -> path("${file}").size() > 0 }.every()}",
                    "Flye assemblies non-empty: ${flye_assemblies.collect { file -> path("${file}").fasta.size() > 0 }.every()}",
                    "Flye graphs non-empty: ${flye_graphs.collect { file -> path("${file}").size() > 0 }.every()}",
                    "MaxBin2 bins non-empty: ${maxbin2_bins.collect { file -> path("${file}").fasta.size() > 0 }.every()}",
                    "MaxBin2 summary rows match bins: ${maxbin2_summary.csv(sep: '\t').rowCount == maxbin2_bins.size()}",
                    "MaxBin2 produced unbinned/discarded output: ${maxbin2_unbins.size() > 0}",
                    "MetaBAT2 bins non-empty when present: ${metabat2_bins.collect { file -> path("${file}").fasta.size() > 0 }.every()}",
                    "MetaBAT2 produced classified or unclassified output: ${metabat2_bins.size() + metabat2_unbins.size() > 0}",
                    "Bin summary non-empty: ${bin_summary.csv(sep: '\t').rowCount > 0}",
                    "Bin summary row count matches bins: ${bin_summary.csv(sep: '\t').rowCount == maxbin2_bins.size() + metabat2_bins.size()}",
                    "BUSCO summary row count matches MaxBin2 bins: ${busco_summary.csv(sep: '\t').rowCount == maxbin2_bins.size()}",
                    "BUSCO batch summaries non-empty: ${busco_batch_summaries.collect { file -> path("${file}").size() > 0 }.every()}",
                ).match("content-checks") },
            )
        }
    }
}
